# Copy to .env and fill in. LRCLIB needs no key, but keep this for future expansion.

# Server
HOST=127.0.0.1
PORT=8000

# Paths (absolute or relative to project root)
DATASETS_DIR=datasets
MODELS_DIR=models
OUTPUTS_DIR=outputs

# Engines (set after setup.sh clones them)
AICOVERGEN_DIR=external/AICoverGen
RVC_WEBUI_DIR=external/RVC-WebUI

# Compute device: auto | cuda | mps | cpu  (auto = detect best available)
DEVICE=auto
